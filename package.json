{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "clear": "php artisan optimize:clear",
        "dev": "vite",
        "dev:all": "concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" -n server,queue,logs,vite \"npm run serve\" \"npm run queue\" \"npm run logs\" \"npm run dev\" --kill-others",
        "format": "php vendor/bin/pint",
        "format:check": "php vendor/bin/pint --test",
        "fresh": "php artisan migrate:fresh --seed",
        "logs": "php artisan pail --timeout=0",
        "queue": "php artisan queue:listen --tries=1 --timeout=0",
        "routes": "php artisan route:list",
        "serve": "php artisan serve --host=127.0.0.1 --port=8000",
        "test": "php artisan test",
        "test:feature": "php artisan test --testsuite=Feature",
        "test:unit": "php artisan test --testsuite=Unit"
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/postcss": "^4.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.2.4",
        "alpinejs": "^3.15.11",
        "autoprefixer": "^10.5.0",
        "axios": "^1.15.2",
        "concurrently": "^9.0.1",
        "gsap": "^3.15.0",
        "laravel-vite-plugin": "^3.0.0",
        "lenis": "^1.3.23",
        "postcss": "^8.5.12",
        "tailwindcss": "^4.2.4",
        "vite": "^8.0.0"
    }
}
